# Example environment variables for local development and Render deployment.
# Create a `.env` file (not committed) and set your real API key there.

# Required: Google Gemini / GenAI API key used by `@google/genai`.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Optional: Application base URL (useful for callbacks or metadata).
# APP_URL="https://your-app.example.com"

# Optional: Port override for local testing (Render provides PORT automatically).
# PORT=3000

# Notes:
# - Do NOT commit your real `.env` to version control. This repo's .gitignore
#   already excludes `.env*` while keeping `.env.example`.
